@model List<string>
@{
    ViewData["Title"] = "Sistem Logları (Serilog)";
}

<div class="card" style="margin-bottom: 20px;">
    <h2>📝 Sistem Log Kayıtları</h2>
    <p style="color: #666;">Uygulamanın çalışması sırasında alınan en son (maksimum 100) Serilog log satırı aşağıda listelenmiştir. Loglar <code>/Logs</code> klasörüne gün bazlı (rolling) olarak yazılmaktadır.</p>
</div>

<div class="card">
    <div style="background-color: #1e1e2d; color: #a2a3b7; padding: 20px; border-radius: 8px; font-family: 'Courier New', Courier, monospace; font-size: 0.9rem; overflow-x: auto; max-height: 600px; overflow-y: auto;">
        
        <div style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px; margin-bottom: 10px;">
            <span style="color: #ffc107;">Log Konsolu Aktif</span>
            <span>@DateTime.Now.ToString("dd.MM.yyyy HH:mm:ss")</span>
        </div>

        @if (Model != null && Model.Any())
        {
            foreach (var log in Model)
            {
                // Renklendirme mantığı (Basitçe kelimelere göre)
                var color = "#a2a3b7";
                if (log.Contains("[INF]")) color = "#28a745";
                else if (log.Contains("[WRN]")) color = "#ffc107";
                else if (log.Contains("[ERR]") || log.Contains("[FTL]")) color = "#dc3545";

                <div style="margin-bottom: 8px; border-bottom: 1px dashed rgba(255,255,255,0.05); padding-bottom: 4px;">
                    <span style="color: @color;">@log</span>
                </div>
            }
        }
        else
        {
            <div style="color: #6c757d;">(Kayıt bulunamadı)</div>
        }
    </div>
</div>
