@model IEnumerable<DapperProjesi.Models.Wallets>

@{
    ViewData["Title"] = "Cüzdan Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-secondary fw-bold">Dijital Cüzdan Yönetimi</h2>
    <a asp-action="EY" class="btn btn-success">+ Yeni Cüzdan Tanımla</a>
</div>

<div class="card shadow border-0">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-3">ID</th>
                    <th>Müşteri (User) ID</th>
                    <th>Cüzdan Numarası</th>
                    <th>Bakiye</th>
                    <th>Para Birimi</th>
                    <th>Son Güncelleme</th>
                    <th class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-bold">@item.Id</td>
                            <td><span class="badge bg-secondary">Kullanıcı #@item.UserId</span></td>
                            <td class="fw-bold text-primary">@item.WalletNumber</td>
                            <td class="text-success fw-bold">@item.Balance.ToString("N2")</td>
                            <td><span class="badge bg-info text-dark">@item.Currency</span></td>
                            <td>@item.UpdatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-center">
                                <a asp-action="EY" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">Düzenle</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('Bu cüzdanı silmek istediğinize emin misiniz? Kullanıcının bakiyesi sıfırlanacaktır!')">Sil</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center p-4 text-muted">Sistemde henüz kayıtlı cüzdan bulunamadı.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>