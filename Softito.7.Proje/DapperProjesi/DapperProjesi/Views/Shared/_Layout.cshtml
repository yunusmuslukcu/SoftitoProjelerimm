@{
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WalletPay Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <style>
            :root {
                --panel-bg: #1e293b;
                --panel-hover: #334155;
                --active-green: #10b981;
            }

            html, body {
                height: 100%;
                margin: 0;
                padding: 0;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                background-color: #f8fafc;
            }

            /* Tüm yapıyı saran ana konteynır */
            .wrapper {
                display: flex;
                flex-direction: column;
                min-height: 100vh;
            }

            /* 1. ÜST BAR (NAVBAR) */
            .navbar-custom {
                background-color: var(--panel-bg);
                border-bottom: 1px solid #334155;
                height: 56px;
            }

            /* Orta gövdeyi (Sidebar + İçerik) ayıran alan */
            .app-body {
                display: flex;
                flex: 1;
                margin-top: 0;
            }

            /* 2. SOL MENÜ (SIDEBAR) */
            .sidebar {
                width: 240px;
                background-color: var(--panel-bg);
                padding-top: 20px;
                box-shadow: 2px 0 5px rgba(0,0,0,0.05);
                flex-shrink: 0;
            }

                .sidebar .nav-link {
                    font-weight: 500;
                    color: #94a3b8;
                    padding: 14px 20px;
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    text-decoration: none;
                    transition: all 0.2s ease;
                    border-left: 4px solid transparent;
                }

                    .sidebar .nav-link:hover {
                        color: #fff;
                        background-color: var(--panel-hover);
                    }

                    .sidebar .nav-link.active-page {
                        color: #fff;
                        background-color: var(--panel-hover);
                        border-left: 4px solid var(--active-green);
                        font-weight: 600;
                    }

            /* 3. ANA İÇERİK ALANI */
            .main-content {
                flex-grow: 1;
                padding: 30px;
                background-color: #f8fafc;
                overflow-y: auto;
            }

            /* 4. EN ALT BAR (FOOTER) */
            .footer-custom {
                background-color: var(--panel-bg);
                color: #94a3b8;
                font-size: 13px;
                height: 40px;
                display: flex;
                align-items: center;
                justify-content: center;
                border-top: 1px solid #334155;
                width: 100%;
                flex-shrink: 0;
            }
    </style>
</head>
<body>

    <div class="wrapper">
        <!-- 1. NAVBAR -->
        <nav class="navbar navbar-dark navbar-custom px-4">
            <a class="navbar-brand fw-bold text-success" asp-controller="Product" asp-action="Index">
                <i class="fa-solid fa-wallet me-2"></i>WalletPay Admin
            </a>
            <div class="ms-auto d-flex align-items-center gap-3">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <span class="text-white-50 small">
                        <i class="fa-solid fa-user-circle me-1 text-success"></i> @User.Identity.Name
                    </span>
                    <a class="btn btn-sm btn-outline-danger border-0 px-2 text-white-50" asp-controller="Account" asp-action="Logout">
                        <i class="fa-solid fa-right-from-bracket"></i> Çıkış
                    </a>
                }
            </div>
        </nav>

        <!-- ORTA GÖVDE -->
        <div class="app-body">
            <!-- 2. SIDEBAR -->
            <div class="sidebar">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Product" ? "active-page" : "")" asp-controller="Product" asp-action="Index">
                            <i class="fa-solid fa-box text-primary"></i> Ürün Yönetimi
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Wallet" ? "active-page" : "")" asp-controller="Wallet" asp-action="Index">
                            <i class="fa-solid fa-credit-card text-success"></i> Cüzdan Yönetimi
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Order" ? "active-page" : "")" asp-controller="Order" asp-action="Index">
                            <i class="fa-solid fa-file-invoice-dollar text-warning"></i> Sipariş & Finans
                        </a>
                    </li>
                </ul>
            </div>

            <!-- 3. MAIN CONTENT -->
            <div class="main-content">
                @RenderBody()
            </div>
        </div>

        <!-- 4. FOOTER -->
        <footer class="footer-custom">
            <div>
                &copy; 2026 - <span class="text-white fw-bold">WalletPay</span> Finansal Yönetim Paneli. Tüm Hakları Saklıdır.
            </div>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>