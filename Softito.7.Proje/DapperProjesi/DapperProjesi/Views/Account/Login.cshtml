@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - WalletPay Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">

<div class="container">
    <div class="row justify-content-center align-items-center vh-100">
        <div class="col-md-5">
            <div class="card shadow border-0 p-4">
                <div class="card-body">
                    <h3 class="text-center mb-4 text-success fw-bold">WalletPay - Yönetim Paneli</h3>
                    
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger" role="alert">
                            @ViewBag.ErrorMessage
                        </div>
                    }
                    
                    <form asp-action="Login" method="post">
                        <div class="mb-3">
                            <label class="form-label">E-posta Adresi</label>
                            <input type="email" name="email" class="form-control" placeholder="ornek@mail.com" required />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Şifre</label>
                            <input type="password" name="passwordHash" class="form-control" placeholder="******" required />
                        </div>
                        
                        <button type="submit" class="btn btn-success w-100 mb-3">Giriş Yap</button>
                    </form>
                    
                    <div class="text-center">
                        <p class="mb-0 small text-muted">Henüz hesabınız yok mu? <a asp-action="Register" class="text-decoration-none fw-bold">Kayıt Ol</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

</body>
</html>