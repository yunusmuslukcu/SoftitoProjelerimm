@model DapperProjesi.Models.Users

@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kayıt Ol - Finance Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">

<div class="container">
    <div class="row justify-content-center align-items-center vh-100">
        <div class="col-md-5">
            <div class="card shadow border-0 p-4">
                <div class="card-body">
                    <h3 class="text-center mb-4 text-primary fw-bold">WalletPay - Kayıt Ol</h3>
                    
                    <form asp-action="Register" method="post">
                        <div class="mb-3">
                            <label class="form-label">Ad Soyad</label>
                            <input type="text" asp-for="FullName" class="form-control" placeholder="Adınızı ve soyadınızı giriniz" required />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">E-posta Adresi</label>
                            <input type="email" asp-for="Email" class="form-control" placeholder="ornek@mail.com" required />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Şifre</label>
                            <input type="password" asp-for="PasswordHash" class="form-control" placeholder="******" required />
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100 mb-3">Hesap Oluştur</button>
                    </form>
                    
                    <div class="text-center">
                        <p class="mb-0 small text-muted">Zaten hesabınız var mı? <a asp-action="Login" class="text-decoration-none fw-bold">Giriş Yap</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

</body>
</html>