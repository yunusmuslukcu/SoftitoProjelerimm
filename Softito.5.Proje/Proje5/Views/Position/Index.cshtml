@{
    ViewData["Title"] = "Pozisyon Yönetimi";
}

<div class="container-fluid mt-4">
    <!-- Header & Action Buttons -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold text-dark mb-1">Pozisyonlar</h2>
            <p class="text-muted mb-0">Sistemde tanımlı futbol pozisyonlarının listesi ve yönetimi.</p>
        </div>
        <button type="button" class="btn btn-primary d-flex align-items-center gap-2 shadow-sm" onclick="OpenAddModal()">
            <i class="fas fa-plus"></i> Yeni Pozisyon Ekle
        </button>
    </div>

    <!-- Search & List Card -->
    <div class="card border-0 shadow-sm rounded-lg overflow-hidden">
        <div class="card-header bg-white py-3 border-bottom d-flex flex-wrap justify-content-between align-items-center gap-3">
            <h5 class="mb-0 fw-semibold text-dark">Pozisyon Listesi</h5>
            <!-- Search bar -->
            <div class="input-group" style="max-width: 320px;">
                <span class="input-group-text bg-light border-end-0 text-muted"><i class="fas fa-search"></i></span>
                <input type="text" id="txtSearchPosition" class="form-control bg-light border-start-0 ps-0" placeholder="Pozisyon adı veya kısaltma ara..." onkeyup="SearchPositionsDebounced(this.value)">
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Pozisyon Adı</th>
                            <th>Kısa Adı</th>
                            <th class="text-end pe-4" style="width: 220px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody id="tblPositionBody">
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">Yükleniyor...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="PositionModal" tabindex="-1" aria-labelledby="PositionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-dark text-white py-3">
                <h5 class="modal-title fw-bold" id="PositionModalLabel">Pozisyon Bilgisi</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body p-4">
                <form id="PositionForm">
                    <input type="hidden" id="PositionId" name="PositionId" />

                    <div class="mb-3">
                        <label for="PositionName" class="form-label fw-semibold text-secondary">Pozisyon Adı</label>
                        <input type="text" class="form-control" id="PositionName" name="PositionName" placeholder="Örn: Santrafor" required>
                    </div>
                    <div class="mb-3">
                        <label for="ShortName" class="form-label fw-semibold text-secondary">Kısa Adı</label>
                        <input type="text" class="form-control" id="ShortName" name="ShortName" placeholder="Örn: ST" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light py-3">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-success px-4" id="btnSave" onclick="SavePosition()">Kaydet</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Position.js" asp-append-version="true"></script>
}