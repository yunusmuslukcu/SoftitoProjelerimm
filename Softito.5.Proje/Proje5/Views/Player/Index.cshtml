@{
    ViewData["Title"] = "Futbolcu Yönetimi";
}

<div class="container-fluid mt-4">
    <!-- Header & Action Buttons -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold text-dark mb-1">Futbolcular</h2>
            <p class="text-muted mb-0">Kulüpte kayıtlı tüm oyuncuların listesi ve yönetimi.</p>
        </div>
        <div class="d-flex gap-2">
            <!-- Red export buttons next to the "Add Player" button -->
            <button type="button" class="btn btn-danger d-flex align-items-center gap-2 shadow-sm" onclick="ExportToPDF()" style="background-color: #dc3545; border-color: #dc3545;">
                <i class="fas fa-file-pdf"></i> PDF İndir
            </button>
            <button type="button" class="btn btn-danger d-flex align-items-center gap-2 shadow-sm" onclick="ExportToWord()" style="background-color: #c82333; border-color: #c82333;">
                <i class="fas fa-file-word"></i> Word İndir
            </button>
            <button type="button" class="btn btn-primary d-flex align-items-center gap-2 shadow-sm" onclick="OpenAddModal()">
                <i class="fas fa-plus"></i> Yeni Futbolcu Ekle
            </button>
        </div>
    </div>

    <!-- Search & List Card -->
    <div class="card border-0 shadow-sm rounded-lg overflow-hidden">
        <div class="card-header bg-white py-3 border-bottom d-flex flex-wrap justify-content-between align-items-center gap-3">
            <h5 class="mb-0 fw-semibold text-dark">Futbolcu Listesi</h5>
            <!-- Search bar -->
            <div class="input-group" style="max-width: 320px;">
                <span class="input-group-text bg-light border-end-0 text-muted"><i class="fas fa-search"></i></span>
                <input type="text" id="txtSearchPlayer" class="form-control bg-light border-start-0 ps-0" placeholder="Futbolcu, takım veya pozisyon ara..." onkeyup="SearchPlayersDebounced(this.value)">
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="playersTable">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Adı</th>
                            <th>Soyadı</th>
                            <th>Yaş</th>
                            <th>Piyasa Değeri</th>
                            <th>Takım</th>
                            <th>Pozisyon</th>
                            <th class="text-end pe-4" style="width: 220px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody id="tblPlayerBody">
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">Yükleniyor...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="PlayerModal" tabindex="-1" aria-labelledby="PlayerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-dark text-white py-3">
                <h5 class="modal-title fw-bold" id="PlayerModalLabel">Futbolcu Bilgisi</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body p-4">
                <form id="PlayerForm">
                    <input type="hidden" id="PlayerId" name="PlayerId" />

                    <div class="mb-3">
                        <label for="FirstName" class="form-label fw-semibold text-secondary">Adı</label>
                        <input type="text" class="form-control" id="FirstName" name="FirstName" required>
                    </div>
                    <div class="mb-3">
                        <label for="LastName" class="form-label fw-semibold text-secondary">Soyadı</label>
                        <input type="text" class="form-control" id="LastName" name="LastName" required>
                    </div>
                    <div class="mb-3">
                        <label for="Age" class="form-label fw-semibold text-secondary">Yaş</label>
                        <input type="number" class="form-control" id="Age" name="Age" required>
                    </div>
                    <div class="mb-3">
                        <label for="MarketValue" class="form-label fw-semibold text-secondary">Piyasa Değeri</label>
                        <input type="text" class="form-control" id="MarketValue" name="MarketValue" placeholder="Örn: 15M €" required>
                    </div>
                    <div class="mb-3">
                        <label for="TeamId" class="form-label fw-semibold text-secondary">Takım</label>
                        <select class="form-select" id="TeamId" name="TeamId">
                            <option value="">Takım Seçiniz (Opsiyonel)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="PositionId" class="form-label fw-semibold text-secondary">Pozisyon</label>
                        <select class="form-select" id="PositionId" name="PositionId">
                            <option value="">Pozisyon Seçiniz (Opsiyonel)</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light py-3">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-success px-4" id="btnSave" onclick="SavePlayer()">Kaydet</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- CDN scripts for PDF generation -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>
    <script src="~/js/Player.js" asp-append-version="true"></script>
}