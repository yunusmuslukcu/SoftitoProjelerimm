@page
@model IndexModel
@{
    ViewData["Title"] = "Genel Portföy Durumu";
}

<div class="container-fluid py-4">
    <!-- Welcome Header Banner -->
    <div class="p-5 mb-4 rounded-3 text-white shadow-sm" style="background: linear-gradient(135deg, #6366f1 0%, #0ea5e9 100%); border-radius: var(--radius-lg) !important;">
        <div class="container-fluid py-2">
            <h1 class="display-5 fw-bold" style="font-family: var(--font-display); letter-spacing: -0.02em;">Hoş Geldiniz!</h1>
            <p class="col-md-8 fs-5 opacity-90">
                Finansal Portföy Takip Sistemi ile hisse senedi ve kripto varlıklarınızı tek bir noktadan yönetin, maliyetlerinizi analiz edin.
            </p>
            <div class="d-flex gap-2 mt-4">
                <a class="btn btn-light text-primary px-4 py-2 border-0 fw-semibold" asp-page="/Stocks/Index" style="border-radius: var(--radius-md) !important;">
                    <i class="bi bi-graph-up-arrow me-1"></i> Hisse Senetleri
                </a>
                <a class="btn btn-primary px-4 py-2 border-0 fw-semibold" asp-page="/Cryptos/Index" style="background-color: rgba(255,255,255,0.15); border-radius: var(--radius-md) !important;">
                    <i class="bi bi-currency-bitcoin me-1"></i> Kripto Paralar
                </a>
            </div>
        </div>
    </div>

    <!-- Quick Stats Cards Grid -->
    <div class="row g-4 mb-4">
        <!-- Stock Stats -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="text-muted fw-semibold" style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Stok Portföyü</span>
                            <div class="bg-success-subtle text-success p-2 rounded-3">
                                <i class="bi bi-graph-up-arrow fs-5"></i>
                            </div>
                        </div>
                        <h2 class="fw-bold text-dark mb-1" style="font-family: var(--font-display);">@Model.TotalStocksValue.ToString("C2")</h2>
                        <p class="text-muted mb-0">Toplam Değer</p>
                    </div>
                    <div class="border-top pt-3 mt-3">
                        <span class="badge bg-success-subtle text-success">@Model.TotalStocksCount Aktif Hisse</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Crypto Stats -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="text-muted fw-semibold" style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Kripto Portföyü</span>
                            <div class="bg-primary-subtle text-primary p-2 rounded-3">
                                <i class="bi bi-currency-bitcoin fs-5"></i>
                            </div>
                        </div>
                        <h2 class="fw-bold text-dark mb-1" style="font-family: var(--font-display);">@Model.TotalCryptosValue.ToString("C2")</h2>
                        <p class="text-muted mb-0">Toplam Değer</p>
                    </div>
                    <div class="border-top pt-3 mt-3">
                        <span class="badge bg-primary-subtle text-primary">@Model.TotalCryptosCount Aktif Kripto</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Stats -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100" style="background: #1e293b !important; color: white !important;">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="text-white-50 fw-semibold" style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Toplam Portföy Değeri</span>
                            <div class="bg-white bg-opacity-10 text-white p-2 rounded-3">
                                <i class="bi bi-wallet2 fs-5"></i>
                            </div>
                        </div>
                        <h2 class="fw-bold text-white mb-1" style="font-family: var(--font-display);">@((Model.TotalStocksValue + Model.TotalCryptosValue).ToString("C2"))</h2>
                        <p class="text-white-50 mb-0">Genel Bakiye</p>
                    </div>
                    <div class="border-top border-secondary pt-3 mt-3">
                        <span class="badge bg-light text-dark">@((Model.TotalStocksCount + Model.TotalCryptosCount)) Toplam Varlık</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
