@page
@model Finansal.PortfoyProject.Pages.Stocks.CreateModel
@{
    ViewData["Title"] = "Yeni Hisse Ekle";
}

<div class="container py-4" style="max-width: 600px;">
    <div class="card shadow-sm border-0">
        <div class="card-header border-0 bg-primary text-white py-3">
            <h5 class="mb-0 fw-bold" style="font-family: var(--font-display);">
                <i class="bi bi-plus-circle me-2"></i>Yeni Hisse Senedi Ekle
            </h5>
        </div>
        <div class="card-body p-4">
            <form method="post">
                <div class="mb-3">
                    <label class="form-label fw-semibold text-secondary">Hisse Kodu (Örn: THYAO)</label>
                    <input type="text" class="form-control form-control-lg border-2" asp-for="NewStock.StockCode" required maxlength="10" placeholder="Hisse sembolünü girin" style="font-family: var(--font-display); text-transform: uppercase;" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold text-secondary">Hisse Adı (Örn: Türk Hava Yolları)</label>
                    <input type="text" class="form-control form-control-lg border-2" asp-for="NewStock.StockName" required placeholder="Hisse şirket adını girin" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold text-secondary">Adet</label>
                        <input type="number" class="form-control form-control-lg border-2" asp-for="NewStock.Quantity" required min="1" placeholder="0" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold text-secondary">Ortalama Alış Fiyatı</label>
                        <input type="number" step="0.01" class="form-control form-control-lg border-2" asp-for="NewStock.AvgPrice" required min="0" placeholder="0.00" />
                    </div>
                </div>

                <div class="d-flex justify-content-between gap-3 mt-4">
                    <a class="btn btn-light border flex-grow-1" asp-page="Index">
                        <i class="bi bi-arrow-left me-1"></i> İptal / Geri Dön
                    </a>
                    <button type="submit" class="btn btn-success flex-grow-1">
                        <i class="bi bi-check-circle me-1"></i> Hisseyi Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
