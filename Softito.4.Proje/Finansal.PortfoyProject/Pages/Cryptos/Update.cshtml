@page
@model Finansal.PortfoyProject.Pages.Cryptos.UpdateModel
@{
    ViewData["Title"] = "Kripto Güncelle";
}

<div class="container py-4" style="max-width: 600px;">
    <div class="card shadow-sm border-0">
        <div class="card-header border-0 bg-warning text-dark py-3">
            <h5 class="mb-0 fw-bold" style="font-family: var(--font-display);">
                <i class="bi bi-pencil-square me-2"></i>Kripto Varlık Bilgilerini Güncelle
            </h5>
        </div>
        <div class="card-body p-4">
            <form method="post">
                <input type="hidden" asp-for="CryptoToEdit.Id" />

                <div class="mb-3">
                    <label class="form-label fw-semibold text-secondary">Kripto Kodu</label>
                    <input type="text" class="form-control form-control-lg border-2" asp-for="CryptoToEdit.CryptoCode" required maxlength="10" style="font-family: var(--font-display); text-transform: uppercase;" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold text-secondary">Kripto Adı</label>
                    <input type="text" class="form-control form-control-lg border-2" asp-for="CryptoToEdit.CryptoName" required />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold text-secondary">Miktar (Adet)</label>
                        <input type="number" step="any" class="form-control form-control-lg border-2" asp-for="CryptoToEdit.Amount" required min="0" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold text-secondary">Ortalama Alış Fiyatı</label>
                        <input type="number" step="0.01" class="form-control form-control-lg border-2" asp-for="CryptoToEdit.AvgPrice" required min="0" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold text-secondary">Cüzdan Adresi (İsteğe Bağlı)</label>
                    <input type="text" class="form-control form-control-lg border-2" asp-for="CryptoToEdit.WalletAddress" />
                </div>

                <div class="d-flex justify-content-between gap-3 mt-4">
                    <a class="btn btn-light border flex-grow-1" asp-page="Index">
                        <i class="bi bi-arrow-left me-1"></i> İptal / Geri Dön
                    </a>
                    <button type="submit" class="btn btn-warning flex-grow-1">
                        <i class="bi bi-check-circle me-1"></i> Değişiklikleri Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
