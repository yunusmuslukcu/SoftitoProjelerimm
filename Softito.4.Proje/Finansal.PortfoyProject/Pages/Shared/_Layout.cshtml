<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Finansal Portföy Paneli</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" />

    <style>
        :root {
            --primary: #6366f1;
            --primary-hover: #4f46e5;
            --secondary: #0ea5e9;
            --dark-bg: #0f172a;
            --sidebar-bg: #1e293b;
            --body-bg: #f8fafc;
            --card-bg: #ffffff;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --border-color: #e2e8f0;
            --radius-lg: 16px;
            --radius-md: 12px;
            --radius-sm: 8px;
            --font-display: 'Outfit', sans-serif;
            --font-sans: 'Inter', sans-serif;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
            --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
        }

        body {
            background-color: var(--body-bg);
            color: var(--text-main);
            font-family: var(--font-sans);
            font-size: 0.95rem;
            overflow-x: hidden;
            letter-spacing: -0.011em;
        }

        /* Sidebar Styling */
        .sidebar {
            min-height: 100vh;
            background-color: var(--sidebar-bg);
            border-right: 1px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .sidebar-brand {
            padding: 24px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .sidebar-brand h5 {
            font-family: var(--font-display);
            font-weight: 800;
            letter-spacing: -0.02em;
            color: #ffffff;
            margin: 0;
            font-size: 1.35rem;
        }

        .sidebar-brand small {
            color: rgba(255, 255, 255, 0.45);
            font-weight: 500;
            text-transform: uppercase;
            font-size: 0.725rem;
            letter-spacing: 0.1em;
            margin-top: 4px;
            display: block;
        }

        /* Navigation Links */
        .sidebar .nav-link {
            color: rgba(255, 255, 255, 0.65);
            padding: 12px 18px;
            font-weight: 500;
            border-radius: var(--radius-sm);
            margin: 6px 16px;
            display: flex;
            align-items: center;
            transition: var(--transition);
        }

        .sidebar .nav-link i {
            font-size: 1.2rem;
            margin-right: 12px;
            transition: var(--transition);
        }

        .sidebar .nav-link:hover {
            color: #ffffff;
            background-color: rgba(255, 255, 255, 0.05);
        }

        .sidebar .nav-link.active {
            color: #ffffff !important;
            background-color: var(--primary);
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.35);
        }

        .sidebar .nav-link.active i {
            transform: scale(1.1);
        }

        /* Topbar Styling */
        .topbar {
            background-color: #ffffff;
            border-bottom: 1px solid var(--border-color);
            padding: 18px 30px;
            box-shadow: var(--shadow-sm);
        }

        .topbar-title {
            font-family: var(--font-display);
            font-weight: 600;
            color: var(--text-main);
            font-size: 1.1rem;
        }

        /* Content Area */
        main {
            padding: 30px;
            background-color: var(--body-bg);
        }

        /* Custom Card Layout */
        .card {
            background-color: var(--card-bg) !important;
            border: 1px solid var(--border-color) !important;
            border-radius: var(--radius-lg) !important;
            box-shadow: var(--shadow-sm) !important;
            transition: var(--transition);
            overflow: hidden;
        }

        .card:hover {
            box-shadow: var(--shadow-md) !important;
            transform: translateY(-2px);
        }

        .card-header {
            background-color: #ffffff !important;
            border-bottom: 1px solid var(--border-color) !important;
            padding: 20px 24px !important;
            font-family: var(--font-display);
            font-weight: 700;
            font-size: 1.15rem;
            color: var(--text-main);
        }

        .card-body {
            padding: 24px !important;
        }

        /* Elegant Table styling */
        .table {
            color: var(--text-main) !important;
            margin-bottom: 0;
            vertical-align: middle;
        }

        .table th {
            font-family: var(--font-display);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            background-color: #f8fafc;
            border-bottom: 2px solid var(--border-color);
            padding: 14px 18px;
        }

        .table td {
            padding: 16px 18px;
            border-bottom: 1px solid var(--border-color);
        }

        .table tr:hover td {
            background-color: #f1f5f9;
        }

        /* Buttons styling */
        .btn {
            font-weight: 600;
            font-size: 0.875rem;
            padding: 10px 20px;
            border-radius: var(--radius-sm);
            transition: var(--transition);
            box-shadow: var(--shadow-sm);
        }

        .btn-sm {
            padding: 6px 12px;
            font-size: 0.8rem;
        }

        .btn-success {
            background-color: #10b981;
            border-color: #10b981;
        }

        .btn-success:hover {
            background-color: #059669;
            border-color: #059669;
        }

        .btn-danger {
            background-color: #ef4444;
            border-color: #ef4444;
            color: white;
        }

        .btn-danger:hover {
            background-color: #dc2626;
            border-color: #dc2626;
            color: white;
        }

        .btn-warning {
            background-color: #f59e0b;
            border-color: #f59e0b;
            color: #ffffff;
        }

        .btn-warning:hover {
            background-color: #d97706;
            border-color: #d97706;
            color: #ffffff;
        }

        /* Badges */
        .badge {
            font-weight: 600;
            padding: 6px 10px;
            border-radius: 6px;
        }

        /* Logout Button */
        .btn-logout {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            color: #ffffff !important;
            border: 1px solid rgba(239, 68, 68, 0.4);
            border-radius: var(--radius-sm);
            font-weight: 600;
            letter-spacing: 0.02em;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.25);
            transition: var(--transition);
        }

        .btn-logout:hover {
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
            color: #ffffff !important;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(239, 68, 68, 0.4);
        }
    </style>
</head>
<body>

    <div class="container-fluid p-0">
        <div class="row g-0">

            <!-- Sidebar -->
            <div class="col-md-3 col-lg-2 sidebar d-flex flex-column">
                <div class="sidebar-brand">
                    <h5>
                        <i class="bi bi-wallet2 text-indigo me-2"></i>Portföyüm
                    </h5>
                    <small>Finansal Takip</small>
                </div>
                <ul class="nav flex-column flex-grow-1 mt-4 px-2">
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path == "/" || Context.Request.Path == "/Index" ? "active" : "")" asp-page="/Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Stocks") ? "active" : "")" asp-page="/Stocks/Index">
                            <i class="bi bi-graph-up-arrow"></i> Stoklar
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Cryptos") ? "active" : "")" asp-page="/Cryptos/Index">
                            <i class="bi bi-currency-bitcoin"></i> Kriptolar
                        </a>
                    </li>
                </ul>
                <div class="p-3 mt-auto border-top" style="border-top: 1px solid rgba(255,255,255,0.08) !important;">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="d-flex align-items-center px-2 py-2 mb-3 rounded" style="background: rgba(255,255,255,0.05);">
                            <div class="bg-primary bg-opacity-25 text-primary rounded-circle p-2 me-2 d-flex align-items-center justify-content-center" style="width: 34px; height: 34px;">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <div class="overflow-hidden">
                                <div class="text-white fw-medium text-truncate" style="font-size: 0.82rem;">@User.Identity.Name</div>
                                <small class="text-white-50 d-block" style="font-size: 0.68rem;">Çevrimiçi</small>
                            </div>
                        </div>
                        <form asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Account/Login")" method="post" class="m-0">
                            <button type="submit" class="btn btn-logout w-100 d-flex align-items-center justify-content-center py-2 px-3">
                                <i class="bi bi-box-arrow-left me-2"></i>
                                <span>Çıkış Yap</span>
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-page="/Account/Login" class="btn btn-primary w-100 d-flex align-items-center justify-content-center py-2 px-3">
                            <i class="bi bi-box-arrow-in-right me-2"></i>
                            <span>Giriş Yap</span>
                        </a>
                    }
                    <div class="text-center mt-3">
                        <small class="text-white-50" style="font-size: 0.68rem; letter-spacing: 0.05em;">PORTFÖY PANELİ v2.0</small>
                    </div>
                </div>
            </div>

            <!-- Main Content Area -->
            <div class="col-md-9 col-lg-10 d-flex flex-column">
                <!-- Topbar -->
                <div class="topbar d-flex justify-content-between align-items-center">
                    <span class="topbar-title"><i class="bi bi-shield-check text-primary me-2"></i>Finansal Portföy Yönetim Paneli</span>
                    <div class="d-flex align-items-center">
                        <div class="bg-light rounded-circle p-2 me-2 d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;">
                            <i class="bi bi-person text-secondary"></i>
                        </div>
                        <span class="fw-semibold text-dark" style="font-size: 0.85rem;">@(User.Identity?.IsAuthenticated == true ? User.Identity.Name : "Misafir")</span>
                    </div>
                </div>

                <!-- Main Content -->
                <main role="main" class="flex-grow-1">
                    @RenderBody()
                </main>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>