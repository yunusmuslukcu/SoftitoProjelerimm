@model IEnumerable<Model.User>
@{
    ViewData["Title"] = "Kullanıcılar";
    ViewData["PageHeader"] = "Kullanıcı Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="text-muted m-0">Sistemdeki personelleri ve departmanlarını yönetin.</p>
    </div>
    <a href="@Url.Action("Create")" class="btn btn-custom btn-custom-primary">
        <i class="bi bi-person-plus"></i> Yeni Kullanıcı Ekle
    </a>
</div>

<div class="card card-custom">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-custom">
                <thead>
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Kullanıcı Adı</th>
                        <th>E-posta</th>
                        <th>Departman</th>
                        <th style="width: 200px; text-align: right;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="fw-bold text-secondary">#@item.Id</span></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-light border d-flex align-items-center justify-content-center text-primary fw-bold me-2" style="width: 35px; height: 35px;">
                                            @item.FullName.Substring(0, Math.Min(item.FullName.Length, 1)).ToUpper()
                                        </div>
                                        <span class="fw-semibold">@item.FullName</span>
                                    </div>
                                </td>
                                <td><span class="text-secondary">@item.Email</span></td>
                                <td>
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">
                                        @item.Department
                                    </span>
                                </td>
                                <td style="text-align: right;">
                                    <a href="@Url.Action("Update", new { id = item.Id })" class="btn btn-sm btn-outline-warning me-1" title="Düzenle">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-sm btn-outline-danger" title="Sil">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr class="no-search">
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-people-fill display-6 d-block mb-3 text-secondary"></i>
                                Kayıtlı kullanıcı bulunamadı.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
