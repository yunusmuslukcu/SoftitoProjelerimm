@model Model.Ticket
@using Model
@{
    ViewData["Title"] = "Talep Sil";
    ViewData["PageHeader"] = "Destek Talebini Sil";
}

<div class="mb-4">
    <a href="@Url.Action("Index")" class="btn btn-custom btn-custom-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Listeye Geri Dön
    </a>
</div>

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card card-custom border-danger">
            <div class="card-header bg-danger text-white py-3">
                <h5 class="m-0"><i class="bi bi-exclamation-triangle-fill me-2"></i>Talebi Silmek İstediğinize Emin Misiniz?</h5>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-warning mb-4">
                    <i class="bi bi-info-circle-fill me-2"></i> Bu işlem geri alınamaz. Seçili destek talebi veritabanından kalıcı olarak silinecektir.
                </div>

                <div class="mb-4">
                    <div class="row mb-3">
                        <div class="col-sm-3 fw-semibold text-muted">Talep ID:</div>
                        <div class="col-sm-9 fw-bold">#@Model.Id</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3 fw-semibold text-muted">Başlık:</div>
                        <div class="col-sm-9 fw-semibold">@Model.Title</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3 fw-semibold text-muted">Kategori:</div>
                        <div class="col-sm-9">
                            <span class="badge bg-light text-dark border">@Model.Category?.Name</span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3 fw-semibold text-muted">Açan Kullanıcı:</div>
                        <div class="col-sm-9">@Model.User?.FullName (@Model.User?.Department)</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3 fw-semibold text-muted">Durum:</div>
                        <div class="col-sm-9">
                            @if (Model.Status == TicketStatus.Open)
                            {
                                <span class="badge-custom badge-open"><i class="bi bi-info-circle me-1"></i> Açık</span>
                            }
                            else if (Model.Status == TicketStatus.InProgress)
                            {
                                <span class="badge-custom badge-progress"><i class="bi bi-gear me-1"></i> İşlemde</span>
                            }
                            else if (Model.Status == TicketStatus.Resolved)
                            {
                                <span class="badge-custom badge-resolved"><i class="bi bi-check-circle me-1"></i> Çözüldü</span>
                            }
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3 fw-semibold text-muted">Açıklama:</div>
                        <div class="col-sm-9 text-secondary bg-light p-3 border rounded" style="white-space: pre-wrap;">@Model.Description</div>
                    </div>
                </div>

                <form action="@Url.Action("Delete")" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-end gap-2">
                        <a href="@Url.Action("Index")" class="btn btn-custom btn-custom-secondary">İptal</a>
                        <button type="submit" class="btn btn-custom btn-custom-danger">
                            <i class="bi bi-trash-fill"></i> Evet, Sil
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
