@model BTProjectt.Models.DashboardViewModel
@using Model
@{
    ViewData["Title"] = "Giriş Paneli";
    ViewData["PageHeader"] = "BT Destek Kontrol Paneli";
}

<!-- Üst Özet Kartları (Metrikler) -->
<div class="row g-3 mb-4">
    <!-- Toplam Talepler -->
    <div class="col-xl-3 col-sm-6">
        <div class="stat-card" style="background: var(--grad-primary);">
            <div class="icon-bg"><i class="bi bi-ticket-perforated"></i></div>
            <h6 class="text-uppercase text-white-50 small">Toplam Talep</h6>
            <h2 class="display-6 fw-bold m-0">@Model.TotalTickets</h2>
            <div class="text-white-50 mt-2 small">Sistemdeki toplam kayıt</div>
        </div>
    </div>
    <!-- Açık Talepler -->
    <div class="col-xl-3 col-sm-6">
        <div class="stat-card" style="background: var(--grad-danger);">
            <div class="icon-bg"><i class="bi bi-info-circle"></i></div>
            <h6 class="text-uppercase text-white-50 small">Yeni/Açık</h6>
            <h2 class="display-6 fw-bold m-0">@Model.OpenTickets</h2>
            <div class="text-white-50 mt-2 small">Çözüm bekleyen talepler</div>
        </div>
    </div>
    <!-- İşlemdekiler -->
    <div class="col-xl-3 col-sm-6">
        <div class="stat-card" style="background: var(--grad-warning);">
            <div class="icon-bg"><i class="bi bi-gear"></i></div>
            <h6 class="text-uppercase text-white-50 small">İşlemde</h6>
            <h2 class="display-6 fw-bold m-0">@Model.InProgressTickets</h2>
            <div class="text-white-50 mt-2 small">İlgilenilen sorunlar</div>
        </div>
    </div>
    <!-- Çözülenler -->
    <div class="col-xl-3 col-sm-6">
        <div class="stat-card" style="background: var(--grad-success);">
            <div class="icon-bg"><i class="bi bi-check-circle"></i></div>
            <h6 class="text-uppercase text-white-50 small">Çözüldü</h6>
            <h2 class="display-6 fw-bold m-0">@Model.ResolvedTickets</h2>
            <div class="text-white-50 mt-2 small">Kapatılmış ve çözülmüş</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- SOL TARAF: SON DESTEK TALEPLERİ -->
    <div class="col-lg-7">
        <div class="card card-custom h-100">
            <div class="card-header card-header-custom bg-white">
                <h5 class="m-0 text-dark fw-bold"><i class="bi bi-clock-history text-primary me-2"></i>Son Destek Talepleri</h5>
                <a href="@Url.Action("Index", "Ticket")" class="btn btn-sm btn-outline-primary rounded-pill">Tümünü Gör</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-custom align-middle">
                        <thead>
                            <tr>
                                <th>Başlık</th>
                                <th>Açan</th>
                                <th>Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentTickets != null && Model.RecentTickets.Any())
                            {
                                foreach (var ticket in Model.RecentTickets)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@ticket.Title</div>
                                            <small class="text-muted">@ticket.Category?.Name</small>
                                        </td>
                                        <td>
                                            <small><i class="bi bi-person me-1"></i>@ticket.User?.FullName</small>
                                        </td>
                                        <td>
                                            @if (ticket.Status == TicketStatus.Open)
                                            {
                                                <span class="badge-custom badge-open">Açık</span>
                                            }
                                            else if (ticket.Status == TicketStatus.InProgress)
                                            {
                                                <span class="badge-custom badge-progress">İşlemde</span>
                                            }
                                            else if (ticket.Status == TicketStatus.Resolved)
                                            {
                                                <span class="badge-custom badge-resolved">Çözüldü</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr class="no-search">
                                    <td colspan="3" class="text-center py-5 text-muted">
                                        Henüz hiç talep oluşturulmamış.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- SAĞ TARAF: KATEGORİ DAĞILIMI GRAFİĞİ -->
    <div class="col-lg-5">
        <div class="card card-custom h-100">
            <div class="card-header card-header-custom bg-white">
                <h5 class="m-0 text-dark fw-bold"><i class="bi bi-pie-chart-fill text-indigo me-2"></i>Kategori Dağılımı</h5>
            </div>
            <div class="card-body d-flex flex-column align-items-center justify-content-center p-4">
                <div style="width: 100%; max-width: 320px; position: relative;">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js Kütüphanesi -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Sunucudan gelen verileri alalım
            const categoryNames = @Json.Serialize(Model.CategoryNames);
            const categoryCounts = @Json.Serialize(Model.CategoryTicketCounts);

            const ctx = document.getElementById('categoryChart').getContext('2d');
            
            // Eğer veri yoksa boş grafik uyarısı verilebilir veya boş dizi olmasın
            if (categoryNames.length === 0) {
                ctx.fillText("Gösterilecek veri yok", 10, 50);
                return;
            }

            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: categoryNames,
                    datasets: [{
                        data: categoryCounts,
                        backgroundColor: [
                            'rgba(99, 102, 241, 0.85)',  // Indigo
                            'rgba(16, 185, 129, 0.85)',  // Green
                            'rgba(245, 158, 11, 0.85)',  // Yellow
                            'rgba(239, 68, 68, 0.85)',   // Red
                            'rgba(59, 130, 246, 0.85)',  // Blue
                            'rgba(168, 85, 247, 0.85)'   // Purple
                        ],
                        borderWidth: 2,
                        borderColor: '#ffffff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                font: {
                                    family: "'Outfit', sans-serif",
                                    size: 11
                                },
                                padding: 15
                            }
                        }
                    },
                    cutout: '65%'
                }
            });
        });
    </script>
}
