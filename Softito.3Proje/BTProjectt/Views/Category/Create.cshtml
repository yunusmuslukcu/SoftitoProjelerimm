@model Model.Category
@{
    ViewData["Title"] = "Yeni Kategori";
    ViewData["PageHeader"] = "Yeni Kategori Ekle";
}

<div class="mb-4">
    <a href="@Url.Action("Index")" class="btn btn-custom btn-custom-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Listeye Geri Dön
    </a>
</div>

<div class="row">
    <div class="col-lg-6 col-md-8 mx-auto">
        <div class="card card-custom">
            <div class="card-header card-header-custom bg-white">
                <h5 class="m-0"><i class="bi bi-tag text-primary me-2"></i>Kategori Detayları</h5>
            </div>
            <div class="card-body p-4">
                <form action="@Url.Action("Create")" method="post">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Kategori Adı</label>
                        <input asp-for="Name" class="form-control form-control-custom" placeholder="Örn: Yazılım Hatası" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-semibold">Açıklama</label>
                        <textarea asp-for="Description" class="form-control form-control-custom" rows="4" placeholder="Kategori açıklaması giriniz..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a href="@Url.Action("Index")" class="btn btn-custom btn-custom-secondary">İptal</a>
                        <button type="submit" class="btn btn-custom btn-custom-primary">
                            <i class="bi bi-check-lg"></i> Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
