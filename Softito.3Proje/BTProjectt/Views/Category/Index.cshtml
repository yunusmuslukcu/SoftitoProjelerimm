@model IEnumerable<Model.Category>
@{
    ViewData["Title"] = "Kategoriler";
    ViewData["PageHeader"] = "Kategori Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="text-muted m-0">Sistemdeki destek kategorilerini yönetin.</p>
    </div>
    <a href="@Url.Action("Create")" class="btn btn-custom btn-custom-primary">
        <i class="bi bi-plus-lg"></i> Yeni Kategori Ekle
    </a>
</div>

<div class="card card-custom">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-custom">
                <thead>
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Kategori Adı</th>
                        <th>Açıklama</th>
                        <th style="width: 200px; text-align: right;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="fw-bold text-secondary">#@item.Id</span></td>
                                <td><span class="fw-semibold">@item.Name</span></td>
                                <td class="text-muted">@item.Description</td>
                                <td style="text-align: right;">
                                    <a href="@Url.Action("Update", new { id = item.Id })" class="btn btn-sm btn-outline-warning me-1" title="Düzenle">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-sm btn-outline-danger" title="Sil">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr class="no-search">
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox-fill display-6 d-block mb-3 text-secondary"></i>
                                Kayıtlı kategori bulunamadı.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
