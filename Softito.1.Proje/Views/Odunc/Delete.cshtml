@model projectcodefrst.Models.Odunc

@{
    ViewData["Title"] = "Ödünç Sil";
}

<h3>Bu ödünç kaydını silmek istediğinize emin misiniz?</h3>
<div>
    <h4>Ödünç Kaydı Detayları</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.AlanKisi)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.AlanKisi)
        </dd>

        <dt class="col-sm-2">
            Kitap
        </dt>
        <dd class="col-sm-10">
            @(Model.Kitap?.KitapAdi ?? "-")
        </dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="OduncId" />
        <input type="submit" value="Sil" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary ms-2">Geri Dön</a>
    </form>
</div>