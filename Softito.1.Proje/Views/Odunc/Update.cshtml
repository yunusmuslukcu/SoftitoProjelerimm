@model projectcodefrst.Models.Odunc

@{
    ViewData["Title"] = "Ödünç Kaydı Güncelle";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-success text-white py-3">
                <h5 class="card-title mb-0"><i class="fas fa-edit me-2"></i>Ödünç Bilgilerini Düzenle</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Update">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="OduncId" />

                    <div class="form-group mb-3">
                        <label asp-for="AlanKisi" class="form-label font-weight-bold">Teslim Alan Kişi</label>
                        <input asp-for="AlanKisi" class="form-control" />
                        <span asp-validation-for="AlanKisi" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="KitapId" class="form-label font-weight-bold">Kitap</label>
                        <select asp-for="KitapId" class="form-select form-control" asp-items="ViewBag.KitapId"></select>
                        <span asp-validation-for="KitapId" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-end border-top pt-3">
                        <a asp-action="Index" class="btn btn-light border me-2"><i class="fas fa-arrow-left me-1"></i>Geri Dön</a>
                        <button type="submit" class="btn btn-success px-4 text-white"><i class="fas fa-save me-1"></i>Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}