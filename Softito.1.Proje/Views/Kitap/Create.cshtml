@model projectcodefrst.Models.Kitap

@{
    ViewData["Title"] = "Kitap Ekle";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="card-title mb-0"><i class="fas fa-book me-2"></i>Yeni Kitap Ekle</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-group mb-3">
                        <label asp-for="KitapAdi" class="form-label font-weight-bold">Kitap Adı</label>
                        <input asp-for="KitapAdi" class="form-control" placeholder="Kitap adını giriniz..." />
                        <span asp-validation-for="KitapAdi" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Sayfa" class="form-label font-weight-bold">Sayfa Sayısı</label>
                        <input asp-for="Sayfa" class="form-control" type="number" placeholder="Sayfa sayısını giriniz..." />
                        <span asp-validation-for="Sayfa" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="YazarId" class="form-label font-weight-bold">Yazar</label>
                        <select asp-for="YazarId" class="form-select form-control" asp-items="ViewBag.YazarId"></select>
                        <span asp-validation-for="YazarId" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="KategoriID" class="form-label font-weight-bold">Kategori</label>
                        <select asp-for="KategoriID" class="form-select form-control" asp-items="ViewBag.KategoriID"></select>
                        <span asp-validation-for="KategoriID" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-end border-top pt-3">
                        <a asp-action="Index" class="btn btn-light border me-2"><i class="fas fa-arrow-left me-1"></i>Geri Dön</a>
                        <button type="submit" class="btn btn-primary px-4"><i class="fas fa-plus me-1"></i>Ekle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>