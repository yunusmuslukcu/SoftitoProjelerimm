@model IEnumerable<projectcodefrst.Models.Kitap>

@{
    ViewData["Title"] = "Kitap Listesi";
}

<div class="card dashboard-card">
    <div class="card-header dashboard-card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fa-solid fa-book me-2 text-primary"></i>Kitap Listesi
        </h5>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fa-solid fa-plus me-2"></i>Kitap Ekle
        </a>
    </div>
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.KitapAdi)</th>
                    <th>@Html.DisplayNameFor(model => model.Sayfa)</th>
                    <th>Yazar</th>
                    <th>Kategori</th>
                    <th style="width: 250px;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold text-dark">@Html.DisplayFor(modelItem => item.KitapAdi)</td>
                        <td>
                            <span class="badge bg-light text-dark px-3 py-2 border">@Html.DisplayFor(modelItem => item.Sayfa) Sayfa</span>
                        </td>
                        <td>@(item.Yazar?.YazarAdi ?? "-")</td>
                        <td>@(item.Kategori?.KategoriAdi ?? "-")</td>
                        <td>
                            <a asp-action="Update" asp-route-id="@item.KitapId" class="btn btn-success me-2">
                                <i class="fa-solid fa-pen-to-square me-2"></i>Güncelle
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.KitapId" class="btn btn-danger">
                                <i class="fa-solid fa-trash-can me-2"></i>Sil
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>