@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BicycleApp - Akıllı Bisiklet Paylaşım Sistemi</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    
    <style>
        :root {
            --primary-color: #4F46E5;
            --secondary-color: #10B981;
            --dark-bg: #0F172A;
            --light-bg: #F8FAFC;
            --text-main: #334155;
            --text-light: #94A3B8;
        }
        
        body {
            font-family: 'Inter', sans-serif;
            color: var(--text-main);
            overflow-x: hidden;
            background-color: var(--light-bg);
        }
        
        h1, h2, h3, h4, h5, h6 {
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
        }

        /* Navbar */
        .navbar-custom {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            transition: all 0.3s ease;
        }
        
        .navbar-brand {
            font-family: 'Outfit', sans-serif;
            font-weight: 800;
            font-size: 1.5rem;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .btn-admin {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            border: none;
            border-radius: 50px;
            padding: 8px 24px;
            font-weight: 600;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .btn-admin:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(79, 70, 229, 0.3);
            color: white;
        }

        /* Hero Section */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.9), rgba(79, 70, 229, 0.8)), url('https://images.unsplash.com/photo-1507035895480-2b3156c31fc8?auto=format&fit=crop&q=80&w=2000') center/cover;
            position: relative;
            padding-top: 80px;
        }
        
        .hero-content {
            color: white;
            z-index: 2;
        }
        
        .hero h1 {
            font-size: 4rem;
            margin-bottom: 1.5rem;
            line-height: 1.2;
        }
        
        .hero p {
            font-size: 1.25rem;
            opacity: 0.9;
            margin-bottom: 2rem;
            font-weight: 300;
        }

        /* Features Section */
        .features {
            padding: 100px 0;
            background-color: white;
        }
        
        .feature-card {
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.05);
            transition: all 0.4s ease;
            height: 100%;
            background: white;
            border: 1px solid rgba(0,0,0,0.05);
        }
        
        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 30px 60px rgba(0,0,0,0.1);
        }
        
        .feature-image {
            height: 250px;
            width: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }
        
        .feature-card:hover .feature-image {
            transform: scale(1.05);
        }
        
        .feature-body {
            padding: 2.5rem;
        }
        
        .feature-icon {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Footer */
        .footer {
            background-color: var(--dark-bg);
            color: white;
            padding: 4rem 0 2rem;
        }
        
        .footer-logo {
            font-family: 'Outfit', sans-serif;
            font-weight: 800;
            font-size: 2rem;
            color: white;
            margin-bottom: 1rem;
            display: inline-block;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-custom fixed-top">
        <div class="container">
            <a class="navbar-brand" href="#">BicycleApp</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav align-items-center">
                    <li class="nav-item me-4">
                        <a class="nav-link fw-medium text-dark" href="#ozellikler">Özellikler</a>
                    </li>
                    <li class="nav-item">
                        <!-- Admin Panel Yönlendirmesi -->
                        <a class="btn btn-admin" href="/Account/Login">
                            <i class="bi bi-shield-lock me-2"></i>Admin Panel
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8 hero-content">
                    <h1>Şehri Keşfetmenin<br>En Özgür Yolu</h1>
                    <p>Modern, çevreci ve sağlıklı bir ulaşım deneyimi. İstasyondan bisikletini al, rotanı belirle ve özgürce sür!</p>
                    <a href="#ozellikler" class="btn btn-light btn-lg rounded-pill px-5 py-3 fw-bold text-primary shadow-lg">Keşfet</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section id="ozellikler" class="features">
        <div class="container">
            <div class="text-center mb-5 pb-3">
                <h2 class="display-5 mb-3">Sistemimiz Nasıl Çalışır?</h2>
                <p class="text-muted fs-5 max-w-2xl mx-auto">Her şey sizin rahatlığınız ve güvenliğiniz için tasarlandı.</p>
            </div>
            
            <div class="row g-5">
                <!-- Bisikletler -->
                <div class="col-lg-4 col-md-6">
                    <div class="feature-card">
                        <img src="https://images.unsplash.com/photo-1485965120184-e220f721d03e?auto=format&fit=crop&q=80&w=800" class="feature-image" alt="Modern Bisikletler">
                        <div class="feature-body text-center">
                            <i class="bi bi-bicycle feature-icon"></i>
                            <h3 class="h4 mb-3">Modern Bisikletler</h3>
                            <p class="text-muted">En yeni teknoloji ile donatılmış, konforlu ve güvenli şehir bisikletlerimizle yolların tadını çıkarın.</p>
                        </div>
                    </div>
                </div>

                <!-- İstasyonlar -->
                <div class="col-lg-4 col-md-6">
                    <div class="feature-card">
                        <img src="https://images.unsplash.com/photo-1517649763962-0c623066013b?auto=format&fit=crop&q=80&w=800" class="feature-image" alt="Akıllı İstasyonlar">
                        <div class="feature-body text-center">
                            <i class="bi bi-geo-alt feature-icon"></i>
                            <h3 class="h4 mb-3">Akıllı İstasyonlar</h3>
                            <p class="text-muted">Şehrin dört bir yanına yayılmış istasyon ağımız sayesinde bisikletlere her an kolayca ulaşın.</p>
                        </div>
                    </div>
                </div>

                <!-- Rotalar -->
                <div class="col-lg-4 col-md-6 offset-md-3 offset-lg-0">
                    <div class="feature-card">
                        <img src="https://images.unsplash.com/photo-1527668752968-14dc70a27c95?auto=format&fit=crop&q=80&w=800" class="feature-image" alt="Keyifli Rotalar">
                        <div class="feature-body text-center">
                            <i class="bi bi-map feature-icon"></i>
                            <h3 class="h4 mb-3">Keyifli Rotalar</h3>
                            <p class="text-muted">Sizin için özel olarak belirlenmiş güvenli bisiklet rotalarında doğanın ve şehrin keyfini sürün.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer text-center">
        <div class="container">
            <a href="#" class="footer-logo text-decoration-none">BicycleApp</a>
            <p class="text-white-50 mb-4">Şehrin akıllı bisiklet paylaşım platformu.</p>
            <hr class="border-secondary opacity-25">
            <p class="text-white-50 small mb-0">&copy; 2026 BicycleApp. Tüm hakları saklıdır.</p>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
