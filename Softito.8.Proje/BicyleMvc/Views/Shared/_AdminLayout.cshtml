<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BicyleApp Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BicyleMvc.styles.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-wrapper">
        <!-- SIDEBAR -->
        <aside class="admin-sidebar d-flex flex-column justify-content-between">
            <div>
                <div class="sidebar-brand d-flex align-items-center justify-content-center py-4 border-bottom border-secondary border-opacity-25">
                    <i class="bi bi-bicycle fs-3 me-2 text-primary"></i>
                    <span class="fs-4 fw-bold text-white tracking-wide">BicyleApp Panel</span>
                </div>
                <div class="sidebar-user p-3 d-flex align-items-center border-bottom border-secondary border-opacity-25">
                    <div class="user-avatar bg-primary text-white d-flex align-items-center justify-content-center rounded-circle me-3" style="width: 40px; height: 40px;">
                        <i class="bi bi-person-fill fs-5"></i>
                    </div>
                    <div>
                        <div class="text-white fw-semibold">@User.Identity?.Name</div>
                        <small class="text-white-50">Admin</small>
                    </div>
                </div>
                <nav class="sidebar-nav mt-3 px-2">
                    <ul class="nav flex-column gap-1">
                        <li class="nav-item">
                            <a class="nav-link text-white d-flex align-items-center gap-3 py-2.5 px-3 rounded @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" 
                               asp-controller="Home" asp-action="Index">
                                <i class="bi bi-speedometer2"></i> Anasayfa
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white d-flex align-items-center gap-3 py-2.5 px-3 rounded @(ViewContext.RouteData.Values["controller"]?.ToString() == "Stations" ? "active" : "")" 
                               asp-controller="Stations" asp-action="Index">
                                <i class="bi bi-geo-alt"></i> İstasyonlar
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white d-flex align-items-center gap-3 py-2.5 px-3 rounded @(ViewContext.RouteData.Values["controller"]?.ToString() == "Rentals" ? "active" : "")" 
                               asp-controller="Rentals" asp-action="Index">
                                <i class="bi bi-card-list"></i> Kiralamalar
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
            
            <!-- Sidebar Bottom: Logout Button -->
            <div class="mt-auto border-top border-secondary border-opacity-25">
                <a class="btn btn-logout w-100 rounded-0 d-flex align-items-center justify-content-center gap-2 py-3 fw-bold" 
                   asp-controller="Account" asp-action="Logout">
                    <i class="bi bi-box-arrow-right"></i> Çıkış Yap
                </a>
            </div>
        </aside>

        <!-- MAIN LAYOUT CONTENT -->
        <div class="admin-content-area">
            <!-- NAVBAR -->
            <header class="admin-navbar d-flex align-items-center justify-content-between px-4">
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-link text-white d-md-none p-0 fs-3" id="sidebarToggle">
                        <i class="bi bi-list"></i>
                    </button>
                    <h5 class="text-white mb-0 fw-semibold d-none d-sm-inline-block">
                        @ViewData["Title"]
                    </h5>
                </div>

                <!-- NAVBAR SEARCH FILTER -->
                <div class="navbar-search">
                    @{
                        string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";
                        string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
                        if (currentController == "Stations" || currentController == "Rentals")
                        {
                            <form method="get" action="@Url.Action(currentAction, currentController)" class="d-flex align-items-center">
                                <div class="input-group">
                                    <span class="input-group-text bg-dark border-secondary border-opacity-25 text-white-50">
                                        <i class="bi bi-search"></i>
                                    </span>
                                    <input type="text" name="searchQuery" class="form-control bg-dark text-white border-secondary border-opacity-25" 
                                           placeholder="Ara..." value="@ViewBag.SearchQuery">
                                    @if (!string.IsNullOrEmpty(ViewBag.SearchQuery))
                                    {
                                        <a href="@Url.Action(currentAction, currentController)" class="btn btn-outline-secondary border-secondary border-opacity-25 d-flex align-items-center">
                                            <i class="bi bi-x-lg"></i>
                                        </a>
                                    }
                                    <button class="btn btn-primary px-3" type="submit">Filtrele</button>
                                </div>
                            </form>
                        }
                    }
                </div>
            </header>

            <!-- PAGE CONTENT -->
            <main role="main" class="admin-main-content p-4">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
                    </div>
                }

                @RenderBody()
            </main>

            <!-- FOOTER -->
            <footer class="admin-footer text-center py-3">
                <div class="container text-white-50">
                    &copy; 2026 - VeloRent Yönetim Paneli - Tüm Hakları Saklıdır.
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            // Sidebar mobil toggle tetikleyici
            $('#sidebarToggle').on('click', function () {
                $('.admin-sidebar').toggleClass('active');
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
