@model BicyleMvc.Models.LoginViewModel
@{
    Layout = null; // Giriş sayfası için genel layout'u kullanmıyoruz, kendine özel tasarımı var.
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - BicyleApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="auth-page">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header text-center">
                <div class="brand-logo-outer mx-auto mb-3">
                    <div class="brand-logo bg-primary text-white d-flex align-items-center justify-content-center rounded-circle">
                        <i class="bi bi-bicycle fs-2"></i>
                    </div>
                </div>
                <h3 class="auth-title">BicyleApp Giriş</h3>
                <p class="auth-subtitle">Bisiklet kiralama yönetim paneline hoş geldiniz</p>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
                </div>
            }

            <form asp-controller="Account" asp-action="Login" method="post" class="mt-4">
                @Html.AntiForgeryToken()
                
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label">E-posta Adresi</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope text-muted"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="ornek@velorent.com" required autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger fs-7"></span>
                </div>

                <div class="form-group mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label asp-for="Password" class="form-label mb-0">Şifre</label>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock text-muted"></i></span>
                        <input asp-for="Password" class="form-control" placeholder="Şifreniz" required />
                    </div>
                    <span asp-validation-for="Password" class="text-danger fs-7"></span>
                </div>

                <button type="submit" class="btn btn-auth w-100 py-2.5 mb-3">Giriş Yap</button>

                <div class="text-center mt-3">
                    <span class="text-muted">Hesabınız yok mu?</span>
                    <a asp-controller="Account" asp-action="Register" class="auth-link fw-semibold ms-1">Kayıt Ol</a>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
