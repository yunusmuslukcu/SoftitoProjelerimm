@model BicyleMvc.Models.RegisterViewModel
@{
    Layout = null; // Kayıt sayfası için genel layout'u kullanmıyoruz, kendine özel tasarımı var.
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kayıt Ol - BicyleApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="auth-page">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header text-center">
                <div class="brand-logo-outer mx-auto mb-3">
                    <div class="brand-logo bg-primary text-white d-flex align-items-center justify-content-center rounded-circle">
                        <i class="bi bi-person-plus fs-2"></i>
                    </div>
                </div>
                <h3 class="auth-title">BicyleApp Kayıt</h3>
                <p class="auth-subtitle">Yeni bir yönetici hesabı oluşturun</p>
            </div>

            <form asp-controller="Account" asp-action="Register" method="post" class="mt-4">
                @Html.AntiForgeryToken()
                
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FirstName" class="form-label">Ad</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person text-muted"></i></span>
                            <input asp-for="FirstName" class="form-control" placeholder="Adınız" required />
                        </div>
                        <span asp-validation-for="FirstName" class="text-danger fs-7"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="LastName" class="form-label">Soyad</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person text-muted"></i></span>
                            <input asp-for="LastName" class="form-control" placeholder="Soyadınız" required />
                        </div>
                        <span asp-validation-for="LastName" class="text-danger fs-7"></span>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label">E-posta Adresi</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope text-muted"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="ornek@velorent.com" required autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger fs-7"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label asp-for="Password" class="form-label">Şifre</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock text-muted"></i></span>
                            <input asp-for="Password" class="form-control" placeholder="Şifreniz" required />
                        </div>
                        <span asp-validation-for="Password" class="text-danger fs-7"></span>
                    </div>
                    <div class="col-md-6 mb-4">
                        <label asp-for="ConfirmPassword" class="form-label">Şifre Tekrarı</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock-fill text-muted"></i></span>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Tekrar" required />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger fs-7"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-auth w-100 py-2.5 mb-3">Kayıt Ol</button>

                <div class="text-center mt-3">
                    <span class="text-muted">Zaten hesabınız var mı?</span>
                    <a asp-controller="Account" asp-action="Login" class="auth-link fw-semibold ms-1">Giriş Yap</a>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
