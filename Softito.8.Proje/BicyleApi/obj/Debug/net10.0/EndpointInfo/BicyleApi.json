            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "userId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "stationId": {
