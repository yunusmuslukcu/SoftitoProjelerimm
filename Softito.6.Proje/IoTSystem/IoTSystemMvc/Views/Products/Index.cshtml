@model IEnumerable<IoTSystemMvc.Models.ProductViewModel>

@{
    ViewData["Title"] = "Ürün Yönetimi";
    var currentFilter = ViewData["CurrentFilter"] as string;
}

<div class="container-fluid">
    <!-- Page Title & Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Ürün Yönetim Paneli</h2>
            <p class="text-muted small mb-0">Sistemde kayıtlı olan tüm IoT donanım ve modülleri listeleyin, arayın ve düzenleyin.</p>
        </div>
        <a href="@Url.Action("Create", "Products")" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Yeni Ürün Ekle
        </a>
    </div>

    <!-- Search / Filter Container -->
    <div class="search-container mb-4">
        <form method="get" action="@Url.Action("Index", "Products")" class="row g-3 align-items-center">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="searchString" value="@currentFilter" class="form-control border-start-0 ps-0" placeholder="Ürün adı veya kodu ile arayın..." />
                </div>
            </div>
            <div class="col-12 col-md-4">
                <button type="submit" class="btn btn-primary me-2">
                    <i class="bi bi-funnel-fill me-1"></i> Filtrele
                </button>
                @if (!string.IsNullOrEmpty(currentFilter))
                {
                    <a href="@Url.Action("Index", "Products")" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i> Temizle
                    </a>
                }
            </div>
        </form>
    </div>

    <!-- Table Card -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Ürün Adı</th>
                            <th>Ürün Kodu</th>
                            <th class="text-end">Birim Fiyatı</th>
                            <th class="text-center">Stok Adedi</th>
                            <th>Kayıt Tarihi</th>
                            <th class="text-center pe-4" style="width: 180px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold text-secondary">@item.Id</td>
                                    <td class="fw-bold text-dark">@item.ProductName</td>
                                    <td><span class="badge bg-light text-secondary border">@item.ProductCode</span></td>
                                    <td class="text-end fw-semibold text-success">@item.UnitPrice.ToString("C0")</td>
                                    <td class="text-center">
                                        <span class="badge @(item.StockQuantity < 50 ? "bg-warning text-dark" : "bg-info")">@item.StockQuantity Adet</span>
                                    </td>
                                    <td>@item.CreatedDate.ToString("yyyy-MM-dd")</td>
                                    <td class="text-center pe-4">
                                        <div class="btn-group" role="group">
                                            <a href="@Url.Action("Edit", "Products", new { id = item.Id })" class="btn btn-outline-warning btn-sm me-1" title="Düzenle">
                                                <i class="bi bi-pencil-square"></i> Düzenle
                                            </a>
                                            <a href="@Url.Action("Delete", "Products", new { id = item.Id })" class="btn btn-outline-danger btn-sm" onclick="return confirm('Bu ürünü silmek istediğinize emin misiniz?')" title="Sil">
                                                <i class="bi bi-trash"></i> Sil
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    <i class="bi bi-emoji-frown fs-1 d-block mb-2 text-secondary"></i>
                                    Listelenecek ürün bulunamadı.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>