@model IEnumerable<IoTSystemMvc.Models.DeviceViewModel>

@{
    ViewData["Title"] = "Cihaz Yönetimi";
    var currentFilter = ViewData["CurrentFilter"] as string;
}

<div class="container-fluid">
    <!-- Page Title & Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">IoT Cihazları Yönetim Paneli</h2>
            <p class="text-muted small mb-0">Sistemde aktif veya pasif durumdaki tüm IoT cihazlarını, ağ bilgilerini ve lokasyonlarını izleyin.</p>
        </div>
        <a href="@Url.Action("Create", "Devices")" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Yeni Cihaz Ekle
        </a>
    </div>

    <!-- Search / Filter Container -->
    <div class="search-container mb-4">
        <form method="get" action="@Url.Action("Index", "Devices")" class="row g-3 align-items-center">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="searchString" value="@currentFilter" class="form-control border-start-0 ps-0" placeholder="Cihaz adı, IP adresi veya konum ile arayın..." />
                </div>
            </div>
            <div class="col-12 col-md-4">
                <button type="submit" class="btn btn-primary me-2">
                    <i class="bi bi-funnel-fill me-1"></i> Filtrele
                </button>
                @if (!string.IsNullOrEmpty(currentFilter))
                {
                    <a href="@Url.Action("Index", "Devices")" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i> Temizle
                    </a>
                }
            </div>
        </form>
    </div>

    <!-- Table Card -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Cihaz Adı</th>
                            <th>IP Adresi</th>
                            <th>MAC Adresi</th>
                            <th class="text-center">Durum</th>
                            <th>Konum</th>
                            <th class="text-center pe-4" style="width: 180px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold text-secondary">@item.Id</td>
                                    <td class="fw-bold text-dark">@item.DeviceName</td>
                                    <td><code class="text-primary">@item.IpAddress</code></td>
                                    <td><code class="text-secondary">@item.MacAddress</code></td>
                                    <td class="text-center">
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle px-2.5 py-1.5"><i class="bi bi-check-circle-fill me-1"></i> Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2.5 py-1.5"><i class="bi bi-x-circle-fill me-1"></i> Pasif</span>
                                        }
                                    </td>
                                    <td><span class="text-muted">@item.Location</span></td>
                                    <td class="text-center pe-4">
                                        <div class="btn-group" role="group">
                                            <a href="@Url.Action("Edit", "Devices", new { id = item.Id })" class="btn btn-outline-warning btn-sm me-1" title="Düzenle">
                                                <i class="bi bi-pencil-square"></i> Düzenle
                                            </a>
                                            <a href="@Url.Action("Delete", "Devices", new { id = item.Id })" class="btn btn-outline-danger btn-sm" onclick="return confirm('Bu cihazı silmek istediğinize emin misiniz?')" title="Sil">
                                                <i class="bi bi-trash"></i> Sil
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    <i class="bi bi-emoji-frown fs-1 d-block mb-2 text-secondary"></i>
                                    Listelenecek cihaz bulunamadı.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>