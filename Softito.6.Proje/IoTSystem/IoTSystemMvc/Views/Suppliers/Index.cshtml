@model IEnumerable<IoTSystemMvc.Models.SupplierViewModel>

@{
    ViewData["Title"] = "Tedarikçi Yönetimi";
    var currentFilter = ViewData["CurrentFilter"] as string;
}

<div class="container-fluid">
    <!-- Page Title & Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Tedarikçi Yönetim Paneli</h2>
            <p class="text-muted small mb-0">Donanım tedarikçilerinizin iletişim bilgileri, adresleri ve yetkili kişilerini yönetin.</p>
        </div>
        <div class="d-flex gap-2">
            <button onclick="exportTableToPDF()" class="btn btn-danger shadow-sm">
                <i class="bi bi-file-pdf me-1"></i> PDF İndir
            </button>
            <button onclick="exportTableToWord('suppliersTable')" class="btn btn-danger shadow-sm">
                <i class="bi bi-file-word me-1"></i> Word İndir
            </button>
            <a href="@Url.Action("Create", "Suppliers")" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle me-1"></i> Yeni Tedarikçi Ekle
            </a>
        </div>
    </div>

    <!-- Search / Filter Container -->
    <div class="search-container mb-4">
        <form method="get" action="@Url.Action("Index", "Suppliers")" class="row g-3 align-items-center">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="searchString" value="@currentFilter" class="form-control border-start-0 ps-0" placeholder="Tedarikçi adı, yetkili veya e-posta ile arayın..." />
                </div>
            </div>
            <div class="col-12 col-md-4">
                <button type="submit" class="btn btn-primary me-2">
                    <i class="bi bi-funnel-fill me-1"></i> Filtrele
                </button>
                @if (!string.IsNullOrEmpty(currentFilter))
                {
                    <a href="@Url.Action("Index", "Suppliers")" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i> Temizle
                    </a>
                }
            </div>
        </form>
    </div>

    <!-- Table Card -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="suppliersTable" class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Tedarikçi Firma</th>
                            <th>Yetkili Kişi</th>
                            <th>Telefon</th>
                            <th>E-posta</th>
                            <th>Adres</th>
                            <th class="text-center pe-4" style="width: 180px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold text-secondary">@item.Id</td>
                                    <td class="fw-bold text-dark">@item.SupplierName</td>
                                    <td>@item.ContactName</td>
                                    <td><span class="text-muted">@item.Phone</span></td>
                                    <td><a href="mailto:@item.Email" class="text-decoration-none">@item.Email</a></td>
                                    <td class="text-wrap" style="max-width: 200px;">@item.Address</td>
                                    <td class="text-center pe-4">
                                        <div class="btn-group" role="group">
                                            <a href="@Url.Action("Edit", "Suppliers", new { id = item.Id })" class="btn btn-outline-warning btn-sm me-1" title="Düzenle">
                                                <i class="bi bi-pencil-square"></i> Düzenle
                                            </a>
                                            <a href="@Url.Action("Delete", "Suppliers", new { id = item.Id })" class="btn btn-outline-danger btn-sm" onclick="return confirm('Bu tedarikçiyi silmek istediğinize emin misiniz?')" title="Sil">
                                                <i class="bi bi-trash"></i> Sil
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    <i class="bi bi-emoji-frown fs-1 d-block mb-2 text-secondary"></i>
                                    Listelenecek tedarikçi bulunamadı.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- jsPDF and AutoTable from CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.23/jspdf.plugin.autotable.min.js"></script>

    <script>
        function exportTableToWord(tableID, filename = 'tedarikciler') {
            var preHtml = "<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'><head><meta charset='utf-8'><title>Tedarikçi Listesi</title><style>table { border-collapse: collapse; width: 100%; } th, td { border: 1px solid #ddd; padding: 8px; text-align: left; } th { background-color: #0f172a; color: white; }</style></head><body>";
            var postHtml = "</body></html>";
            
            var table = document.getElementById(tableID);
            var cleanTableHtml = "<table>";
            
            // Header (Excluding the actions column)
            cleanTableHtml += "<thead><tr>";
            var headers = table.querySelectorAll("thead th");
            for (var i = 0; i < headers.length - 1; i++) {
                cleanTableHtml += "<th>" + headers[i].innerText + "</th>";
            }
            cleanTableHtml += "</tr></thead><tbody>";
            
            // Rows (Excluding the actions column)
            var rows = table.querySelectorAll("tbody tr");
            rows.forEach(function(row) {
                if (row.cells.length > 1) {
                    cleanTableHtml += "<tr>";
                    for (var i = 0; i < row.cells.length - 1; i++) {
                        cleanTableHtml += "<td>" + row.cells[i].innerText + "</td>";
                    }
                    cleanTableHtml += "</tr>";
                }
            });
            cleanTableHtml += "</tbody></table>";

            var html = preHtml + cleanTableHtml + postHtml;

            var blob = new Blob(['\ufeff' + html], {
                type: 'application/msword'
            });
            
            var url = URL.createObjectURL(blob);
            var a = document.createElement("a");
            a.href = url;
            a.download = filename + ".doc";
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }

        async function exportTableToPDF() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            
            doc.setFont("helvetica", "bold");
            doc.setFontSize(16);
            doc.text("Tedarikçi Listesi", 14, 15);
            doc.setFontSize(10);
            doc.setFont("helvetica", "normal");
            doc.text("Tarih: " + new Date().toLocaleDateString('tr-TR'), 14, 22);

            const table = document.getElementById("suppliersTable");
            const headers = [];
            const tableHeaders = table.querySelectorAll("thead th");
            for (let i = 0; i < tableHeaders.length - 1; i++) {
                headers.push(tableHeaders[i].innerText);
            }

            const rows = [];
            const tableRows = table.querySelectorAll("tbody tr");
            tableRows.forEach(row => {
                if (row.cells.length > 1) {
                    const rowData = [];
                    for (let i = 0; i < row.cells.length - 1; i++) {
                        rowData.push(row.cells[i].innerText);
                    }
                    rows.push(rowData);
                }
            });

            doc.autoTable({
                head: [headers],
                body: rows,
                startY: 28,
                theme: 'striped',
                headStyles: { fillColor: [15, 23, 42] }, // Slate 900 matching header
                styles: { font: "helvetica", fontSize: 9 }
            });

            doc.save("tedarikciler.pdf");
        }
    </script>
}