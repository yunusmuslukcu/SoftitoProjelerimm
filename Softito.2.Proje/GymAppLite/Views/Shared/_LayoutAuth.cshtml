<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - GymAppLite</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="~/startbootstrap-sb-admin-gh-pages/css/styles.css" rel="stylesheet" />
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
    <style>
        body {
            font-family: 'Outfit', 'Plus Jakarta Sans', sans-serif !important;
            background-color: #0f172a;
            position: relative;
            min-height: 100vh;
            overflow-x: hidden;
        }

        .auth-bg-slider {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
        }
        .auth-slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            opacity: 0;
            animation: authBgSlide 20s infinite linear;
        }
        .auth-slide:nth-child(1) {
            background-image: url('https://images.unsplash.com/photo-518611012118-696072aa579a?q=80&w=1920&auto=format&fit=crop');
            animation-delay: 0s;
        }
        .auth-slide:nth-child(2) {
            background-image: url('https://images.unsplash.com/photo-534438327276-14e5300c3a48?q=80&w=1920&auto=format&fit=crop');
            animation-delay: 10s;
        }

        @@keyframes authBgSlide {
            0% { opacity: 0; transform: scale(1); }
            10% { opacity: 0.55; }
            45% { opacity: 0.55; transform: scale(1.05); }
            55% { opacity: 0; transform: scale(1.06); }
            100% { opacity: 0; }
        }

        .auth-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.85) 0%, rgba(30, 41, 59, 0.88) 100%);
            z-index: 1;
        }

        #layoutAuthentication {
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .card.auth-card {
            background: rgba(30, 41, 59, 0.85) !important;
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.12) !important;
            border-radius: 20px !important;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5) !important;
            color: #f8fafc;
        }

        .auth-card .card-header {
            background: rgba(15, 23, 42, 0.6) !important;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08) !important;
            border-top-left-radius: 20px !important;
            border-top-right-radius: 20px !important;
            padding: 2rem !important;
        }

        .auth-card .card-body {
            background: transparent !important;
            color: #f8fafc !important;
            padding: 2.5rem !important;
        }

        .auth-card .card-footer {
            background: rgba(15, 23, 42, 0.6) !important;
            border-top: 1px solid rgba(255, 255, 255, 0.08) !important;
            border-bottom-left-radius: 20px !important;
            border-bottom-right-radius: 20px !important;
            padding: 1.25rem !important;
        }

        .form-floating > label {
            color: #64748b !important;
        }
        .form-floating > .form-control {
            background-color: #0f172a !important;
            border: 1px solid #334155 !important;
            color: #ffffff !important;
            border-radius: 12px;
        }
        .form-floating > .form-control:focus {
            border-color: #6366f1 !important;
            box-shadow: 0 0 0 0.2rem rgba(99, 102, 241, 0.25) !important;
        }

        .btn-glow {
            background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);
            color: #fff !important;
            font-weight: 700;
            padding: 0.75rem 2rem;
            border-radius: 12px;
            border: none;
            box-shadow: 0 4px 20px rgba(79, 70, 229, 0.4);
            transition: all 0.3s ease;
        }
        .btn-glow:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(99, 102, 241, 0.6);
        }
    </style>
</head>
<body>
    <div class="auth-bg-slider">
        <div class="auth-slide"></div>
        <div class="auth-slide"></div>
    </div>
    <div class="auth-overlay"></div>

    <div id="layoutAuthentication">
        <div id="layoutAuthentication_content">
            <main>
                <div class="container py-5">
                    @RenderBody()
                </div>
            </main>
        </div>
        <div id="layoutAuthentication_footer">
            <footer class="py-4 mt-auto" style="border-top: 1px solid rgba(255,255,255,0.05);">
                <div class="container-fluid px-4">
                    <div class="d-flex align-items-center justify-content-between small text-white-50">
                        <div>Copyright &copy; GymAppLite 2026 &middot; Rengi sidebar ile uyumlu.</div>
                        <div>
                            <a href="@Url.Action("Landing", "Home")" class="text-white-50 me-3">Web Sitesine Dön</a>
                            <a href="#" class="text-white-50">Gizlilik</a>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="~/startbootstrap-sb-admin-gh-pages/js/scripts.js"></script>
</body>
</html>
