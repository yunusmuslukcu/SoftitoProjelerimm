@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "_LayoutAuth";
}

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card auth-card mt-5">
            <div class="card-header text-center">
                <div class="mb-2">
                    <span class="badge bg-primary px-3 py-2 text-uppercase" style="letter-spacing: 1px;">⚡ PROFESYONEL YÖNETİM PORTALI</span>
                </div>
                <h3 class="font-weight-bold text-white my-2">GymAppLite Girişi</h3>
                <p class="text-muted small mb-0">Antrometrik takip, periyodizasyon ve salon yönetimi için oturum açın</p>
            </div>
            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger" style="border-radius: 12px; background: rgba(244, 63, 94, 0.15); border: 1px solid #f43f5e; color: #fda4af;">
                        @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                    </div>
                }
                <form method="post" action="@Url.Action("Login", "Account")">
                    <div class="form-floating mb-3">
                        <input class="form-control" id="inputEmail" type="email" name="email" placeholder="name@example.com" required />
                        <label for="inputEmail">E-posta Adresi</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input class="form-control" id="inputPassword" type="password" name="password" placeholder="Şifre" required />
                        <label for="inputPassword">Şifre</label>
                    </div>
                    <div class="form-check mb-4">
                        <input class="form-check-input" id="inputRememberPassword" type="checkbox" name="rememberMe" value="true" />
                        <label class="form-check-label text-muted" for="inputRememberPassword">Beni Hatırla</label>
                    </div>
                    <div class="d-flex align-items-center justify-content-between mt-4 mb-0">
                        <a class="small text-muted" href="#">Şifremi Unuttum?</a>
                        <button class="btn btn-glow" type="submit"><i class="fas fa-sign-in-alt me-2"></i>Giriş Yap</button>
                    </div>
                </form>
            </div>
            <div class="card-footer text-center">
                <div class="small"><a href="@Url.Action("Register", "Account")" style="color: #818cf8; text-decoration: none; font-weight: 600;">Hesabınız yok mu? Kurumsal Ağığımıza Katılın!</a></div>
            </div>
        </div>
    </div>
</div>
