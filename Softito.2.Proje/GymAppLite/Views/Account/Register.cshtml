@{
    ViewData["Title"] = "Kayıt Ol";
    Layout = "_LayoutAuth";
}

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card auth-card mt-5">
            <div class="card-header text-center">
                <div class="mb-2">
                    <span class="badge bg-primary px-3 py-2 text-uppercase" style="letter-spacing: 1px;">⚡ KURUMSAL KAYIT</span>
                </div>
                <h3 class="font-weight-bold text-white my-2">Yeni Hesap Oluştur</h3>
                <p class="text-muted small mb-0">GymAppLite ekosistemine katılın, atletik performans metriklerini dijitalleştirin</p>
            </div>
            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger" style="border-radius: 12px; background: rgba(244, 63, 94, 0.15); border: 1px solid #f43f5e; color: #fda4af;">
                        @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                    </div>
                }
                <form method="post" action="@Url.Action("Register", "Account")">
                    <div class="form-floating mb-3">
                        <input class="form-control" id="inputEmail" type="email" name="email" placeholder="name@example.com" required />
                        <label for="inputEmail">E-posta Adresi</label>
                    </div>
                    <div class="form-floating mb-4">
                        <input class="form-control" id="inputPassword" type="password" name="password" placeholder="Şifre" required />
                        <label for="inputPassword">Şifre</label>
                    </div>
                    <div class="d-flex align-items-center justify-content-between mt-4 mb-0">
                        <button class="btn btn-glow w-100 justify-content-center" type="submit"><i class="fas fa-user-plus me-2"></i>Hemen Kayıt Ol</button>
                    </div>
                </form>
            </div>
            <div class="card-footer text-center">
                <div class="small"><a href="@Url.Action("Login", "Account")" style="color: #818cf8; text-decoration: none; font-weight: 600;">Zaten hesabınız var mı? Giriş Yapın!</a></div>
            </div>
        </div>
    </div>
</div>
