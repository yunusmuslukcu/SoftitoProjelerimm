@model GymAppLite.Models.SubscriptionType

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">✏️ Paket Düzenle</h6>
    </div>
    <div class="card-body">
        <form href="@Url.Action("Update", "SubscriptionType")" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="form-group mb-3">
                <label>Paket Adı</label>
                <input asp-for="TypeName" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label>Fiyatı</label>
                <input asp-for="Price" type="number" step="0.01" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-info">Güncelle</button>
            <a href="@Url.Action("Index", "SubscriptionType")" class="btn btn-secondary">İptal</a>
        </form>
    </div>
</div>