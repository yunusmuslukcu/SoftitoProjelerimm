@model IEnumerable<GymAppLite.Models.SubscriptionType>

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">🏋️‍♂️ Üyelik Paketleri Listesi</h6>
        <a href="@Url.Action("Create", "SubscriptionType")" class="btn btn-primary btn-sm">➕ Yeni Paket Ekle</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Paket Adı</th>
                        <th>Fiyatı</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.TypeName</td>
                            <td>@item.Price.ToString("C2")</td>
                            <td>
                                <a href="@Url.Action("Update", "SubscriptionType", new { id = item.Id })" class="btn btn-warning btn-sm">✏️ Düzenle</a>
                                <a href="@Url.Action("Delete", "SubscriptionType", new { id = item.Id })" class="btn btn-danger btn-sm">🗑️ Sil</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>