@model IEnumerable<GymAppLite.Models.ProgressLog>

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">📈 Üye Gelişim Takip Listesi</h6>
        <a href="@Url.ActionLink("Create", "ProgressLogs")" class="btn btn-primary btn-sm">➕ Yeni Ölçüm Ekle</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Ölçüm No (ID)</th>
                        <th>Üye Adı Soyadı</th>
                        <th>Kilo (kg)</th>
                        <th>Boy (cm)</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            
                            <td>
                                @(item.Member != null ? $"{item.Member.FirstName} {item.Member.LastName}" : "Üye Bulunamadı")
                            </td>
                            <td>@item.Weight kg</td>
                            <td>@item.Height cm</td>
                            <td>
                                <a href="@Url.ActionLink("Update", "ProgressLogs", new { id = item.Id })" class="btn btn-warning btn-sm">✏️ Düzenle</a>
                                <a href="@Url.ActionLink("Delete", "ProgressLogs", new { id = item.Id })" class="btn btn-danger btn-sm">🗑️ Sil</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>