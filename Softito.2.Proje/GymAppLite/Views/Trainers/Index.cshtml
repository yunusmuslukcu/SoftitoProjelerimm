@model IEnumerable<GymAppLite.Models.Trainer>

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">📋 Antrenör Listesi</h6>
        <a href="@Url.Action("Create", "Trainers")" class="btn btn-primary btn-sm">➕ Yeni Antrenör Ekle</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Ad Soyad</th>
                        <th>Uzmanlık Alanı</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.FullName</td>
                            <td>@item.Expertise</td>
                            <td>
                                <a href="@Url.Action("Update", "Trainers", new { id = item.Id })" class="btn btn-warning btn-sm">✏️ Düzenle</a>
                                <a href="@Url.Action("Delete", "Trainers", new { id = item.Id })" class="btn btn-danger btn-sm">🗑️ Sil</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>