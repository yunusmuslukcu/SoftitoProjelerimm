@model GymAppLite.Models.Member

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">➕ Yeni Üye Ekle</h6>
    </div>
    <div class="card-body">
        <form action="@Url.ActionLink("Create", "Members")" method="post">
            <div class="form-group mb-3">
                <label>Üye Adı</label>
                <input asp-for="FirstName" class="form-control" placeholder="Örn: Yunus" required />
            </div>
            <div class="form-group mb-3">
                <label>Üye Soyadı</label>
                <input asp-for="LastName" class="form-control" placeholder="Örn: Muslukcu" required />
            </div>

            
            <div class="form-group mb-3">
                <label>Üyelik Paketi Seçin</label>
                <select asp-for="SubscriptionTypeId" class="form-control" required>
                    <option value="">-- Paket Seçiniz --</option>
                    @foreach (var type in ViewBag.SubscriptionTypes)
                    {
                        <option value="@type.Id">@type.TypeName (@type.Price.ToString("C2"))</option>
                    }
                </select>
            </div>

         
            <div class="form-group mb-3">
                <label>Antrenör Seçin</label>
                <select asp-for="TrainerId" class="form-control" required>
                    <option value="">-- Antrenör Seçiniz --</option>
                    @foreach (var trainer in ViewBag.Trainers)
                    {
                        <option value="@trainer.Id">@trainer.FullName</option>
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-success">Kaydet</button>
            <a href="@Url.ActionLink("Index", "Members")" class="btn btn-secondary">İptal</a>
        </form>
    </div>
</div>